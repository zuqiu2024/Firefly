---
/* src/components/Twikoo.astro */
---

<div id="tcomment" class="mt-12 py-6 border-t border-gray-200 dark:border-gray-800"></div>

<script is:inline src="https://cdn.staticfile.org/twikoo/1.6.39/twikoo.all.min.js"></script>

<script>
  function initTwikoo() {
    const container = document.getElementById('tcomment');
    if (container && typeof twikoo !== 'undefined') {
      twikoo.init({
        envId: 'https://pinglun-sigma-seven.vercel.app', // 刚才部署成功的 Vercel 域名
        el: '#tcomment',
        // path: window.location.pathname, // 可选：手动指定路径
      });
    }
  }

  // 1. 初始加载执行
  initTwikoo();

  // 2. 兼容 Astro 的 View Transitions (如果你的模板用了这个功能)
  document.addEventListener('astro:page-load', initTwikoo);
</script>

<style is:global>
  /* 针对 Tailwind 暗色模式的微调 */
  .dark .tk-content, .dark .tk-nick, .dark .tk-time {
    color: #e5e7eb !important;
  }
  .dark .tk-preview-container {
    background-color: #1f2937 !important;
  }
  /* 自定义主色调（比如蓝色） */
  :root {
    --tk-color-primary: #3b82f6;
  }
</style>